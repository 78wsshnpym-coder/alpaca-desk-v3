        "const express = require(\"express\");",
        "const https = require(\"https\");",
        "const app = express();",
        "app.use(express.json());",
        "function apiCall(host, path, method, headers, body) {",
        "return new Promise(function(resolve, reject) {",
        "var options = {",
        "hostname: host,",
        "path: path,",
        "method: method || \"GET\",",
        "headers: Object.assign({ \"Content-Type\": \"application/json\" }, headers)",
        "};",
        "var r = https.request(options, function(res) {",
        "var data = \"\";",
        "res.on(\"data\", function(chunk) { data += chunk; });",
        "res.on(\"end\", function() {",
        "try { resolve({ status: res.statusCode, body: JSON.parse(data) }); }",
        "catch(e) { resolve({ status: res.statusCode, body: { raw: data } }); }",
        "});",
        "});",
        "r.on(\"error\", reject);",
        "if (body) r.write(JSON.stringify(body));",
        "r.end();",
        "});",
        "}",
        "app.get(\"/api/test\", async function(req, res) {",
        "var key = req.headers[\"key_id\"];",
        "var sec = req.headers[\"secret_key\"];",
        "if (!key || !sec) return res.json({ ok: false, error: \"Geen keys\" });",
        "try {",
        "var r = await apiCall(\"paper-api.alpaca.markets\", \"/v2/account\", \"GET\", {",
        "\"APCA-API-KEY-ID\": key,",
        "\"APCA-API-SECRET-KEY\": sec",
        "}, null);",
        "if (r.body && r.body.equity) {",
        "res.json({ ok: true, equity: r.body.equity });",
        "} else {",
        "res.json({ ok: false, error: r.body.message || \"Ongeldige keys\" });",
        "}",
        "} catch(e) {",
        "res.json({ ok: false, error: e.message });",
        "}",
        "});",
        "app.all(\"/api/alpaca/*\", async function(req, res) {",
        "var key = req.headers[\"key_id\"];",
        "var sec = req.headers[\"secret_key\"];",
        "var path = \"/v2/\" + req.params[0];",
        "var qs = req.url.indexOf(\"?\") > -1 ? req.url.slice(req.url.indexOf(\"?\")) : \"\";",
        "var headers = { \"APCA-API-KEY-ID\": key, \"APCA-API-SECRET-KEY\": sec };",
        "try {",
        "var body = [\"POST\", \"PUT\", \"PATCH\"].includes(req.method) ? req.body : null;",
        "var r = await apiCall(\"paper-api.alpaca.markets\", path + qs, req.method, headers, body);",
        "res.status(r.status).json(r.body);",
        "} catch(e) {",
        "res.status(500).json({ error: e.message });",
        "}",
        "});",
        "app.all(\"/api/data/*\", async function(req, res) {",
        "var key = req.headers[\"key_id\"];",
        "var sec = req.headers[\"secret_key\"];",
        "var path = \"/v2/\" + req.params[0];",
        "var qs = req.url.indexOf(\"?\") > -1 ? req.url.slice(req.url.indexOf(\"?\")) : \"\";",
        "var headers = { \"APCA-API-KEY-ID\": key, \"APCA-API-SECRET-KEY\": sec };",
        "try {",
        "var r = await apiCall(\"data.alpaca.markets\", path + qs, \"GET\", headers, null);",
        "res.status(r.status).json(r.body);",
        "} catch(e) {",
        "res.status(500).json({ error: e.message });",
        "}",
        "});",
        "app.get(\"/\", function(req, res) {",
        "res.setHeader(\"Content-Type\", \"text/html\");",
        "res.end(getHTML());",
        "});",
