        "lines.push(\"</style></head><body>\");",
        "lines.push(\"<div id='setup'>\");",
        "lines.push(\"  <div class='si'>&#9672;</div>\");",
        "lines.push(\"  <div class='st'>ALPHA DESK</div>\");",
        "lines.push(\"  <div class='ss'>Vul je Alpaca Paper Trading<br>API keys in om te verbinden</div>\");",
        "lines.push(\"  <input class='sinp' id='ik' placeholder='API Key ID (PK...)' autocomplete='off' autocorrect='off' autocapitalize='none' spellcheck='false'>\");",
        "lines.push(\"  <input class='sinp' id='is' type='password' placeholder='Secret Key' autocomplete='off' spellcheck='false'>\");",
        "lines.push(\"  <button class='sbtn' id='cbtn' onclick='connect()'>&#9672; Verbinden</button>\");",
        "lines.push(\"  <div class='serr' id='serr'></div>\");",
        "lines.push(\"</div>\");",
        "lines.push(\"<div id='app' class='hidden'>\");",
        "lines.push(\"  <header><div class='ht'><div class='logo'><div class='li'>&#9672;</div><div class='lt'>ALPHA DESK<span class='ld'></span></div></div><button class='rb' onclick='fetchAll()'>&#8635; Refresh</button></div><div class='ut' id='ut'>Verbinden...</div></header>\");",
        "lines.push(\"  <div id='eb' class='ebar hidden'></div>\");",
        "lines.push(\"  <div class='ks'><div class='kpi'><div class='kl'>Portfolio</div><div class='kv' id='keq'>-</div></div><div class='kpi'><div class='kl'>Dag P&amp;L</div><div class='kv' id='kpnl'>-</div><div class='ksub' id='kpct'>-</div></div><div class='kpi'><div class='kl'>Posities</div><div class='kv' id='kpos'>-</div><div class='ksub' id='kca'>-</div></div></div>\");",
        "lines.push(\"  <div id='tp' class='con'></div>\");",
        "lines.push(\"  <div id='to' class='con hidden'></div>\");",
        "lines.push(\"  <div id='tw' class='con hidden'></div>\");",
        "lines.push(\"  <div id='th' class='con hidden'></div>\");",
        "lines.push(\"  <nav class='bnav'>\");",
        "lines.push(\"    <button class='nb active' onclick=\\\"gt('p')\\\" id='np'><span class='ni'>&#128188;</span>Portfolio</button>\");",
        "lines.push(\"    <button class='nb' onclick=\\\"gt('o')\\\" id='no'><span class='ni'>&#128221;</span>Order</button>\");",
        "lines.push(\"    <button class='nb' onclick=\\\"gt('w')\\\" id='nw'><span class='ni'>&#128065;</span>Watchlist</button>\");",
        "lines.push(\"    <button class='nb' onclick=\\\"gt('h')\\\" id='nh'><span class='ni'>&#128203;</span>Historie</button>\");",
        "lines.push(\"  </nav>\");",
        "lines.push(\"</div>\");",
        "lines.push(\"<script>\");",
        "lines.push(\"var K='',S='',acc=null,pos=[],ord=[],qt={},tab='p';\");",
        "lines.push(\"var WL=['NVDA','META','MSFT','AAPL','TSM','NFLX','AMD','AMZN'];\");",
        "lines.push(\"var OS={t:'NVDA',s:'buy',tp:'market',q:1,lp:''};\");",
        "lines.push(\"async function connect(){\");",
        "lines.push(\"  K=document.getElementById('ik').value.trim();\");",
        "lines.push(\"  S=document.getElementById('is').value.trim();\");",
        "lines.push(\"  var err=document.getElementById('serr'),btn=document.getElementById('cbtn');\");",
        "lines.push(\"  err.textContent='';\");",
        "lines.push(\"  if(!K||!S){err.textContent='Vul beide velden in';return;}\");",
        "lines.push(\"  btn.textContent='Verbinden...';btn.disabled=true;\");",
        "lines.push(\"  try{\");",
        "lines.push(\"    var r=await fetch('/api/test',{headers:{'key_id':K,'secret_key':S}});\");",
        "lines.push(\"    var d=await r.json();\");",
        "lines.push(\"    if(d.ok){\");",
        "lines.push(\"      document.getElementById('setup').classList.add('hidden');\");",
        "lines.push(\"      document.getElementById('app').classList.remove('hidden');\");",
        "lines.push(\"      fetchAll();setInterval(fetchAll,30000);\");",
        "lines.push(\"    }else{err.textContent='Fout: '+(d.error||'Ongeldige keys');btn.textContent='Verbinden';btn.disabled=false;}\");",
        "lines.push(\"  }catch(e){err.textContent='Serverfout: '+e.message;btn.textContent='Verbinden';btn.disabled=false;}\");",
        "lines.push(\"}\");",
        "lines.push(\"async function af(p,o){o=o||{};var r=await fetch('/api/alpaca/'+p,{method:o.method||'GET',headers:{'key_id':K,'secret_key':S,'Content-Type':'application/json'},body:o.body?JSON.stringify(o.body):undefined});return r.json();}\");",
        "lines.push(\"async function df(p){var r=await fetch('/api/data/'+p,{headers:{'key_id':K,'secret_key':S}});return r.json();}\");",
        "lines.push(\"async function fetchAll(){\");",
        "lines.push(\"  try{\");",
        "lines.push(\"    se(null);\");",
        "lines.push(\"    var a=await af('account');if(a.code)throw new Error(a.message||'API fout');\");",
        "lines.push(\"    acc=a;pos=await af('positions');ord=await af('orders?status=all&limit=30');\");",
        "lines.push(\"    pos=Array.isArray(pos)?pos:[];ord=Array.isArray(ord)?ord:[];\");",
        "lines.push(\"    var sy=Array.from(new Set(WL.concat(pos.map(function(p){return p.symbol})))).join(',');\");",
        "lines.push(\"    try{var q=await df('stocks/quotes/latest?symbols='+sy);qt=q.quotes||{};}catch(e){}\");",
        "lines.push(\"    updKPI();rdr();\");",
        "lines.push(\"    document.getElementById('ut').textContent='Bijgewerkt: '+new Date().toLocaleTimeString('nl-NL',{hour:'2-digit',minute:'2-digit',second:'2-digit'});\");",
        "lines.push(\"  }catch(e){se(e.message);}\");",
        "lines.push(\"}\");",
        "lines.push(\"function updKPI(){if(!acc)return;var eq=parseFloat(acc.equity),le=parseFloat(acc.last_equity),pnl=eq-le,pct=(pnl/le)*100,ca=parseFloat(acc.cash);sv('keq','$'+eq.toFixed(2));sv('kpnl',fu(pnl),pnl>=0?'green':'red');sv('kpct',fp(pct),pnl>=0?'green':'red');sv('kpos',pos.length+' open');sv('kca','cash $'+ca.toFixed(0));}\");",
        "lines.push(\"function gt(t){tab=t;[{id:'p',el:'tp'},{id:'o',el:'to'},{id:'w',el:'tw'},{id:'h',el:'th'}].forEach(function(x){document.getElementById(x.el).classList.toggle('hidden',x.id!==t);document.getElementById('n'+x.id).classList.toggle('active',x.id===t);});rdr();}\");",
        "lines.push(\"function rdr(){if(tab==='p')rPort();else if(tab==='o')rOrd();else if(tab==='w')rWatch();else if(tab==='h')rHist();}\");",
        "lines.push(\"function rPort(){var el=document.getElementById('tp');if(!pos.length){el.innerHTML='<div class=\\\"sec\\\">Portfolio</div><div class=\\\"empty\\\"><div class=\\\"ei\\\">&#128219;</div>Geen posities<br><small>Ga naar Order</small></div>';return;}var tp=pos.reduce(function(s,p){return s+parseFloat(p.unrealized_pl||0)},0);el.innerHTML='<div class=\\\"sec\\\">Posities - '+fu(tp)+'</div>'+pos.map(pc).join('');}\");",
        "lines.push(\"function pc(p){var pl=parseFloat(p.unrealized_pl),plp=parseFloat(p.unrealized_plpc)*100,il=p.side==='long';var en=parseFloat(p.avg_entry_price),cu=parseFloat(p.current_price),mv=parseFloat(p.market_value);var tg=il?en*1.02:en*0.98,st=il?en*0.99:en*1.01;return '<div class=\\\"card\\\" style=\\\"border-color:'+(pl>=0?'rgba(0,229,160,.25)':'rgba(255,77,109,.2)')+'\\\"><div class=\\\"ch\\\"><div><div class=\\\"tk\\\">'+p.symbol+'</div><div class=\\\"sn\\\">'+p.qty+' aandelen</div></div><div class=\\\"bgs\\\"><span class=\\\"badge '+(il?'bl':'bs')+'\\\">'+(il?'LONG':'SHORT')+'</span><span class=\\\"'+(pl>=0?'green':'red')+'\\\" style=\\\"font-size:17px;font-weight:800\\\">'+fu(pl)+'</span></div></div><div class=\\\"pg\\\"><div class=\\\"pb\\\"><div class=\\\"pbl\\\">Entry</div><div class=\\\"pbv\\\" style=\\\"color:#94a3b8\\\">$'+en.toFixed(2)+'</div></div><div class=\\\"pb\\\"><div class=\\\"pbl\\\">Huidig</div><div class=\\\"pbv\\\" style=\\\"color:#e2e8f0\\\">$'+cu.toFixed(2)+'</div></div><div class=\\\"pb\\\"><div class=\\\"pbl\\\">Mkt Wrd</div><div class=\\\"pbv purple\\\">$'+mv.toFixed(0)+'</div></div><div class=\\\"pb\\\"><div class=\\\"pbl\\\">P&L %</div><div class=\\\"pbv '+(pl>=0?'green':'red')+'\\\">'+plp.toFixed(2)+'%</div></div></div><div class=\\\"sug\\\"><span class=\\\"green\\\">Target $'+tg.toFixed(2)+'</span><span class=\\\"red\\\">Stop $'+st.toFixed(2)+'</span></div><button class=\\\"bcl\\\" onclick=\\\"cp(this.dataset.s)\\\" data-s=\\\"'+p.symbol+'\\\">Positie Sluiten</button></div>';}\");",
        "lines.push(\"async function cp(sym){if(!confirm(sym+' sluiten?'))return;await fetch('/api/alpaca/positions/'+sym,{method:'DELETE',headers:{'key_id':K,'secret_key':S}});setTimeout(fetchAll,1500);}\");",
        "lines.push(\"function rOrd(){var el=document.getElementById('to');var q=qt[OS.t],mid=q?(parseFloat(q.ap)+parseFloat(q.bp))/2:null;var il=OS.s==='buy',en=mid||100;var tg=il?en*1.02:en*0.98,st=il?en*0.99:en*1.01;var rw=Math.abs((tg-en)*OS.q),ri=Math.abs((st-en)*OS.q);var h='<div class=\\\"sec\\\">Order Plaatsen</div><div class=\\\"card\\\">';h+='<div class=\\\"fg\\\"><label class=\\\"fl\\\">Ticker</label><input class=\\\"fi\\\" id=\\\"ot\\\" value=\\\"'+OS.t+'\\\" oninput=\\\"OS.t=this.value.toUpperCase();this.value=OS.t;rOrd()\\\" autocorrect=\\\"off\\\" autocapitalize=\\\"characters\\\"></div>';h+='<div class=\\\"fg\\\"><label class=\\\"fl\\\">Richting</label><div class=\\\"tgl\\\"><button class=\\\"to '+(OS.s==='buy'?'ob':'')+' \\\" id=\\\"bb\\\" onclick=\\\"OS.s=this.dataset.v;rOrd()\\\" data-v=\\\"buy\\\">LONG</button><button class=\\\"to '+(OS.s==='sell'?'os2':'')+' \\\" id=\\\"bs\\\" onclick=\\\"OS.s=this.dataset.v;rOrd()\\\" data-v=\\\"sell\\\">SHORT</button></div></div>';h+='<div class=\\\"fg\\\"><label class=\\\"fl\\\">Aantal</label><input class=\\\"fi\\\" type=\\\"number\\\" min=\\\"1\\\" value=\\\"'+OS.q+'\\\" oninput=\\\"OS.q=parseInt(this.value)||1;rOrd()\\\" inputmode=\\\"numeric\\\"></div>';h+='<div class=\\\"fg\\\"><label class=\\\"fl\\\">Type</label><div class=\\\"tgl\\\"><button class=\\\"to '+(OS.tp==='market'?'ot2':'')+' \\\" onclick=\\\"OS.tp=this.dataset.v;rOrd()\\\" data-v=\\\"market\\\">Market</button><button class=\\\"to '+(OS.tp==='limit'?'ot2':'')+' \\\" onclick=\\\"OS.tp=this.dataset.v;rOrd()\\\" data-v=\\\"limit\\\">Limit</button></div></div>';if(OS.tp==='limit')h+='<div class=\\\"fg\\\"><label class=\\\"fl\\\">Limietprijs</label><input class=\\\"fi\\\" type=\\\"number\\\" step=\\\"0.01\\\" value=\\\"'+OS.lp+'\\\" oninput=\\\"OS.lp=this.value\\\" inputmode=\\\"decimal\\\"></div>';h+='<button class=\\\"pbtn '+(il?'pbb':'pbs')+'\\\" onclick=\\\"po()\\\">'+(il?'LONG':'SHORT')+' '+OS.t+' x'+OS.q+' '+OS.tp.toUpperCase()+'</button><div id=\\\"or\\\"></div></div>';h+='<div class=\\\"sec\\\" style=\\\"margin-top:14px\\\">Risico Calculator</div><div class=\\\"card\\\">';h+='<div class=\\\"rrow\\\"><span class=\\\"rl\\\">Koers</span><span class=\\\"rv\\\">'+(mid?'$'+mid.toFixed(2):'geen quote')+'</span></div>';h+='<div class=\\\"rrow\\\"><span class=\\\"rl\\\">Target +2%</span><span class=\\\"rv green\\\">$'+tg.toFixed(2)+'</span></div>';h+='<div class=\\\"rrow\\\"><span class=\\\"rl\\\">Stop -1%</span><span class=\\\"rv red\\\">$'+st.toFixed(2)+'</span></div>';h+='<div class=\\\"rrow\\\"><span class=\\\"rl\\\">Max winst</span><span class=\\\"rv green\\\">$'+rw.toFixed(2)+'</span></div>';h+='<div class=\\\"rrow\\\"><span class=\\\"rl\\\">Max verlies</span><span class=\\\"rv red\\\">$'+ri.toFixed(2)+'</span></div>';h+='<div class=\\\"rrow\\\"><span class=\\\"rl\\\">R/R Ratio</span><span class=\\\"rv purple\\\">2:1</span></div></div>';h+='<div class=\\\"sec\\\" style=\\\"margin-top:14px\\\">Snelle selectie</div><div style=\\\"display:flex;flex-wrap:wrap;padding-bottom:10px\\\">';WL.forEach(function(s){h+='<button class=\\\"qs\\\" onclick=\\\"OS.t=this.dataset.s;rOrd()\\\" data-s=\\\"'+s+'\\\">'+s+'</button>';});h+='</div>';el.innerHTML=h;}\");",
        "lines.push(\"async function po(){var r=document.getElementById('or');if(r)r.innerHTML='<div class=\\\"ook\\\">Verwerken...</div>';try{var b={symbol:OS.t,qty:String(OS.q),side:OS.s,type:OS.tp,time_in_force:'day'};if(OS.tp==='limit')b.limit_price=OS.lp;var res=await fetch('/api/alpaca/orders',{method:'POST',headers:{'key_id':K,'secret_key':S,'Content-Type':'application/json'},body:JSON.stringify(b)});var d=await res.json();if(d.id){if(r)r.innerHTML='<div class=\\\"ook\\\">Geplaatst! '+d.symbol+' '+d.side.toUpperCase()+' '+d.qty+'</div>';setTimeout(fetchAll,2000);}else throw new Error(d.message||JSON.stringify(d));}catch(e){if(r)r.innerHTML='<div class=\\\"oer\\\">Fout: '+e.message+'</div>';}}\");",
        "lines.push(\"function rWatch(){var el=document.getElementById('tw');var hq=Object.keys(qt).length>0;var h='<div class=\\\"sec\\\">Watchlist</div>';if(!hq)h+='<div class=\\\"empty\\\"><div class=\\\"ei\\\">&#128225;</div>Geen quotes<br><small>Markt opent 15:30 NL</small></div>';WL.forEach(function(s){var q=qt[s],a=q?parseFloat(q.ap):null,b=q?parseFloat(q.bp):null;var m=a&&b?(a+b)/2:null,sp=a&&b?((a-b)/a*100).toFixed(3):null;h+='<div class=\\\"wc\\\"><div class=\\\"wh\\\"><div class=\\\"tk\\\">'+s+'</div><div class=\\\"wp\\\">'+(m?'$'+m.toFixed(2):'geen data')+'</div></div>';if(q){h+='<div class=\\\"wg\\\"><div class=\\\"pb\\\"><div class=\\\"pbl\\\">Bid</div><div class=\\\"pbv red\\\">$'+b.toFixed(2)+'</div></div><div class=\\\"pb\\\"><div class=\\\"pbl\\\">Ask</div><div class=\\\"pbv green\\\">$'+a.toFixed(2)+'</div></div><div class=\\\"pb\\\"><div class=\\\"pbl\\\">Spread</div><div class=\\\"pbv yellow\\\">'+sp+'%</div></div></div>';}else{h+='<div style=\\\"color:var(--mu);font-size:12px;text-align:center;margin-bottom:9px\\\">Geen quote</div>';}h+='<div class=\\\"wb\\\"><button class=\\\"wbt\\\" style=\\\"color:var(--gr);border-color:var(--gr);background:rgba(0,229,160,.08)\\\" onclick=\\\"OS.t=this.dataset.s;OS.s=this.dataset.d;gt(\\\\'o\\\\')\\\" data-s=\\\"'+s+'\\\" data-d=\\\"buy\\\">Long</button><button class=\\\"wbt\\\" style=\\\"color:var(--re);border-color:var(--re);background:rgba(255,77,109,.08)\\\" onclick=\\\"OS.t=this.dataset.s;OS.s=this.dataset.d;gt(\\\\'o\\\\')\\\" data-s=\\\"'+s+'\\\" data-d=\\\"sell\\\">Short</button></div></div>';});el.innerHTML=h;}\");",
        "lines.push(\"function rHist(){var el=document.getElementById('th');if(!ord.length){el.innerHTML='<div class=\\\"sec\\\">Historie</div><div class=\\\"empty\\\"><div class=\\\"ei\\\">&#128219;</div>Nog geen orders</div>';return;}var h='<div class=\\\"sec\\\">Geschiedenis ('+ord.length+')</div>';ord.forEach(function(o){var il=o.side==='buy';var sc=o.status==='filled'?'bf':o.status==='canceled'||o.status==='expired'?'bc':'bn';var pr=o.filled_avg_price?'$'+parseFloat(o.filled_avg_price).toFixed(2):o.limit_price?'lmt $'+parseFloat(o.limit_price).toFixed(2):'market';var ti=new Date(o.created_at).toLocaleTimeString('nl-NL',{hour:'2-digit',minute:'2-digit'});h+='<div class=\\\"oc\\\"><div><div class=\\\"osym\\\">'+o.symbol+' <span class=\\\"badge '+(il?'bl':'bs')+'\\\">'+(il?'BUY':'SELL')+'</span></div><div class=\\\"ometa\\\">'+o.qty+' x '+o.type+' - <span class=\\\"badge '+sc+'\\\">'+o.status+'</span></div></div><div><div class=\\\"oprice\\\">'+pr+'</div><div class=\\\"otime\\\">'+ti+'</div></div></div>';});el.innerHTML=h;}\");",
        "lines.push(\"function fu(v){return(v>=0?'+':'-')+'$'+Math.abs(v).toFixed(2);}\");",
